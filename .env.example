# =============================================================================
# Maestro AI — environment configuration
# Copy this file to ".env" and fill in the values, then `docker compose up -d`.
# =============================================================================
# NOTE: never commit your real .env. Only this .env.example belongs in git.


# -----------------------------------------------------------------------------
# Compose / project
# -----------------------------------------------------------------------------
# Port the dashboard is served on (host side). Default 4400.
DASHBOARD_PORT=4400

# Timezone for n8n scheduling and logs (IANA name, e.g. America/Los_Angeles).
GENERIC_TIMEZONE=America/Los_Angeles


# -----------------------------------------------------------------------------
# n8n — workflow engine
# -----------------------------------------------------------------------------
# Basic-auth credentials for the n8n UI (http://localhost:5678).
# CHANGE THESE before first start.
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=

# Google Drive folder ID where the pipeline creates per-job folders.
# (The parent folder under which résumé/cover-letter folders are made.)
ROOT_FOLDER_ID=


# -----------------------------------------------------------------------------
# Dashboard — Google Sheets (service account)
# -----------------------------------------------------------------------------
# The service-account email (…@….iam.gserviceaccount.com).
GOOGLE_SHEETS_CLIENT_EMAIL=

# The service-account private key, on ONE line with literal \n for newlines.
# Example: GOOGLE_SHEETS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"
# Keep the surrounding quotes. Do NOT paste a multi-line key — it must be a
# single line; the app un-escapes the \n at runtime.
GOOGLE_SHEETS_PRIVATE_KEY=

# The spreadsheet ID of your Maestro database (from the Sheet URL:
# https://docs.google.com/spreadsheets/d/<THIS_ID>/edit).
GOOGLE_SHEETS_DATABASE_ID=


# -----------------------------------------------------------------------------
# Dashboard — Google Drive (OAuth2 as user)
# Used to save generated résumés / cover letters to your Drive.
# -----------------------------------------------------------------------------
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=

# Optional: Drive folder ID to save résumés/cover letters into.
# Leave blank to use the Drive root.
GOOGLE_RESUMES_PARENT_ID=


# -----------------------------------------------------------------------------
# Dashboard <-> n8n wiring
# -----------------------------------------------------------------------------
# Cross-container webhook base. Leave as-is when running via docker compose
# (the dashboard reaches n8n by its service name, not localhost).
N8N_WEBHOOK_BASE_URL=http://n8n:5678/webhook

# Shared secret sent as the X-Maestro-Secret header on webhook calls.
# Must match the value your n8n workflows expect. Choose a strong random value.
MAESTRO_WEBHOOK_SECRET=
